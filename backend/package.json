{
  "name": "etal-backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm install && npm run build-lambda && npm prune --omit=dev",
    "build-lambda": "esbuild src/lambda.js --bundle --platform=node --target=node18 --outfile=dist/lambda.js --external:aws-sdk --keep-names --minify=false"
  },
  "dependencies": {
    "body-parser": "^1.20.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1400",
    "serverless-http": "^3.1.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "esbuild": "^0.17.0"
  }
}
